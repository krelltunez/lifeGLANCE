VITE_WEBDAV_PROXY_URL=https://lifeglance.app

# Set to 1 ONLY in the hosted (Vercel) build to enable the "load demo data"
# feature (sample-persona timeline for evaluators + ?demo=1 deep link). Leave
# unset for Docker / self-hosted / Capacitor builds — when unset, all demo code
# and its fixture JSON are tree-shaken out of the bundle.
# VITE_DEMO=1
